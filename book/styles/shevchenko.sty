\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{shevchenko}[2026/07/15 Proceedings style for MPTM 2026]

\RequirePackage[a4paper,top=20mm,bottom=22mm,left=22mm,right=22mm]{geometry}
\RequirePackage{mathtools}
\RequirePackage{libertinus}

\RequirePackage{microtype}
\RequirePackage{booktabs}
\RequirePackage{enumitem}
\RequirePackage{xurl}
\RequirePackage[hidelinks]{hyperref}
\RequirePackage[nameinlink,noabbrev]{cleveref}
\RequirePackage{ragged2e}
\RequirePackage{graphicx}
\RequirePackage{wrapfig}
\RequirePackage{caption}
\RequirePackage{tikz}
\RequirePackage{pgfplots}
\pgfplotsset{compat=1.18}
\usetikzlibrary{calc,angles,quotes}

\setlength{\parindent}{1.25em}
\setlength{\parskip}{0pt}
\allowdisplaybreaks
\renewcommand{\theequation}{\arabic{equation}}
\renewcommand{\figurename}{Рис.}
\renewcommand{\tablename}{Табл.}
\newcounter{report}
\renewcommand{\theHequation}{\arabic{report}.\arabic{equation}}
\renewcommand{\theHfigure}{\arabic{report}.\arabic{figure}}
\renewcommand{\theHtable}{\arabic{report}.\arabic{table}}
\setcounter{secnumdepth}{0}
\emergencystretch=2em

\newcommand{\avg}[2][]{\left\langle #2\right\rangle_{#1}}
\newcommand{\Extr}{\operatorname{Extr}}
\newcommand{\dd}{\,\mathrm{d}}

\newcommand{\ReportHeading}[4]{%
  \clearpage
  \refstepcounter{report}%
  \setcounter{equation}{0}%
  \setcounter{figure}{0}%
  \setcounter{table}{0}%
  \phantomsection
  \addcontentsline{toc}{section}{#1}%
  \begin{center}
    {\Large\bfseries #1\par}
    \vspace{0.8em}
    {\large\bfseries #2\par}
    \vspace{0.35em}
    {#3\par}
    \if\relax\detokenize{#4}\relax\else\href{mailto:#4}{\nolinkurl{#4}}\fi
  \end{center}
  \vspace{0.8em}
}
